# NZ Legal RAG Configuration
# Copy this file to .env and customize

# ============================================
# DATABASE PATHS
# ============================================
CHROMA_DB_PATH=./chroma_db
TENANT_DATA_PATH=./tenant_data

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=mixtral:latest

# Alternative models (uncomment to use):
# LLM_MODEL=mistral:latest
# LLM_MODEL=llama3.1:latest

# ============================================
# API SERVER CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ============================================
# SECURITY
# ============================================
# IMPORTANT: Change this to a secure random key in production!
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change-this-in-production-to-a-secure-random-string

# ============================================
# DATA PATHS
# ============================================
LEGISLATION_DATA_PATH=./data/legislation
CASE_LAW_DATA_PATH=./data/case_law
POLICE_MANUAL_PATH=./data/police_manual

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CONFIDENTIAL_DOCS=true
ENABLE_API=true

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/nz_legal_rag.log
